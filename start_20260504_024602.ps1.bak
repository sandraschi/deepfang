# DeepFang start — docker-compose up + supervisor + dashboard.
$ErrorActionPreference = "Stop"
$RepoRoot = $PSScriptRoot
Set-Location $RepoRoot

Write-Host "=== DeepFang Goliath Stack ===" -ForegroundColor Cyan

# 1. Verify .env exists
if (-not (Test-Path ".env")) {
    Write-Error ".env not found. Run .\setup.ps1 first."
    exit 1
}

$envContent = Get-Content ".env" -Raw
if ($envContent -match "DEEPSEEK_API_KEY=sk-xxxxxxxx" -or $envContent -notmatch "DEEPSEEK_API_KEY=sk-") {
    Write-Warning "DEEPSEEK_API_KEY not set in .env. DeepSeek adjudication will fail."
}

# 2. Monitoring stack (Prometheus, Loki, Grafana)
Write-Host "[1/3] Starting observability stack ..." -ForegroundColor Cyan
docker compose -f docker-compose.yml up -d prometheus loki promtail grafana
if (-not $?) { Write-Error "Monitoring stack failed to start."; exit 1 }

# 3. Core pipeline (ZeroClaw, DeepSeek, Moltbot, Supervisor)
Write-Host "[2/3] Starting core pipeline ..." -ForegroundColor Cyan
docker compose -f docker-compose.yml up -d zeroclaw deepseek-bridge moltbot supervisor
if (-not $?) { Write-Error "Core pipeline failed to start."; exit 1 }

# 4. Dashboard
Write-Host "[3/3] Starting dashboard ..." -ForegroundColor Cyan
$DashDir = Join-Path $RepoRoot "dashboard"
if (Test-Path (Join-Path $DashDir "package.json")) {
    Set-Location $DashDir
    Start-Process npm -ArgumentList "run","dev" -WindowStyle Minimized
    Set-Location $RepoRoot
}

Write-Host ""
Write-Host "DeepFang stack is running:" -ForegroundColor Green
Write-Host "  Supervisor + MCP:  http://localhost:10930" -ForegroundColor White
Write-Host "  Dashboard:        http://localhost:10931" -ForegroundColor White
Write-Host "  ZeroClaw (MCP):   http://localhost:10932" -ForegroundColor White
Write-Host "  DeepSeek Bridge:  http://localhost:10933" -ForegroundColor White
Write-Host "  Moltbot Worker:   http://localhost:10934" -ForegroundColor White
Write-Host "  Grafana:          http://localhost:10937" -ForegroundColor White
Write-Host ""
Write-Host "Run 'docker compose -f docker-compose.yml down' to stop." -ForegroundColor DarkGray
