# DeepFang — Goliath Docker-Compose Stack
# Copy to .env and fill in your values.

# ── DeepSeek-V4-Pro Adjudicator ─────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Sanitizer (optional Ollama LLM pass for ambiguous content) ──────────────
# Leave blank to use regex-only mode (fast, no LLM cost)
SANITIZER_LLM_URL=
SANITIZER_LLM_MODEL=qwen2.5:7b

# ── Worker (optional Ollama task→commands generation) ───────────────────────
# Leave blank to use command mode only (no natural language tasks)
# Goliath: http://host.docker.internal:11434
WORKER_OLLAMA_URL=
WORKER_OLLAMA_MODEL=qwen2.5:14b

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Git Mirrors (worker writes here) ────────────────────────────────────────
GIT_ROOT=d:/dev/repos
