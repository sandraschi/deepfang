import { useState, useEffect, useCallback } from "react";
import {
  Shield,
  Gavel,
  Wrench,
  Activity,
  CheckCircle,
  XCircle,
  AlertTriangle,
  RefreshCw,
  Play,
  Clock,
  GitBranch,
} from "lucide-react";
import axios from "axios";

const API = "http://localhost:10930";

interface HealthData {
  status: string;
  uptime_seconds: number;
  services: Record<string, string>;
  adjudication_log_count: number;
}

interface AuditEntry {
  timestamp: string;
  content: string;
  verdict: string;
  rationale: string;
  sanitize_score: number;
}

function ServiceStatus({ name, status }: { name: string; status: string }) {
  const icon =
    status === "healthy" ? (
      <CheckCircle className="w-4 h-4 text-green-400" />
    ) : (
      <XCircle className="w-4 h-4 text-red-400" />
    );
  const color = status === "healthy" ? "border-green-500/20 bg-green-500/5" : "border-red-500/20 bg-red-500/5";
  return (
    <div className={`flex items-center gap-2 px-3 py-2 rounded border ${color}`}>
      {icon}
      <span className="text-sm font-medium capitalize">{name}</span>
      <span className="text-xs text-zinc-500 ml-auto">{status}</span>
    </div>
  );
}

function PipelineStage({
  icon: Icon,
  label,
  port,
  active,
}: {
  icon: React.ComponentType<{ className?: string }>;
  label: string;
  port: number;
  active: boolean;
}) {
  return (
    <div
      className={`flex flex-col items-center gap-1 p-4 rounded-lg border transition-colors ${
        active ? "border-blue-500/30 bg-blue-500/5" : "border-zinc-800 bg-zinc-900"
      }`}
    >
      <Icon className={`w-6 h-6 ${active ? "text-blue-400" : "text-zinc-600"}`} />
      <span className="text-sm font-medium">{label}</span>
      <span className="text-xs text-zinc-500">:{port}</span>
    </div>
  );
}

export default function App() {
  const [health, setHealth] = useState<HealthData | null>(null);
  const [auditLog, setAuditLog] = useState<AuditEntry[]>([]);
  const [input, setInput] = useState("");
  const [result, setResult] = useState<string | null>(null);
  const [loading, setLoading] = useState(false);

  const fetchHealth = useCallback(async () => {
    try {
      const { data } = await axios.get<HealthData>(`${API}/health`);
      setHealth(data);
    } catch {
      setHealth(null);
    }
  }, []);

  const fetchAudit = useCallback(async () => {
    try {
      const { data } = await axios.get(`${API}/api/audit?limit=20`);
      setAuditLog(data.entries || []);
    } catch {
      // ignore
    }
  }, []);

  useEffect(() => {
    fetchHealth();
    fetchAudit();
    const i = setInterval(fetchHealth, 5000);
    return () => clearInterval(i);
  }, [fetchHealth, fetchAudit]);

  const runPipeline = async () => {
    if (!input.trim()) return;
    setLoading(true);
    setResult(null);
    try {
      const { data } = await axios.post(`${API}/api/pipeline`, { content: input, source: "dashboard" });
      setResult(JSON.stringify(data, null, 2));
      fetchAudit();
    } catch (e: unknown) {
      const msg = e instanceof Error ? e.message : String(e);
      setResult(`Error: ${msg}`);
    } finally {
      setLoading(false);
    }
  };

  return (
    <div className="max-w-6xl mx-auto p-6 space-y-6">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-3">
          <GitBranch className="w-8 h-8 text-blue-400" />
          <div>
            <h1 className="text-2xl font-bold">DeepFang</h1>
            <p className="text-sm text-zinc-500">Goliath Isolation Stack</p>
          </div>
        </div>
        <div className="flex items-center gap-3">
          <span
            className={`flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium ${
              health?.status === "healthy"
                ? "bg-green-500/10 text-green-400 border border-green-500/20"
                : "bg-yellow-500/10 text-yellow-400 border border-yellow-500/20"
            }`}
          >
            <Activity className="w-3 h-3" />
            {health?.status || "offline"}
          </span>
          <button onClick={fetchHealth} className="p-2 rounded hover:bg-zinc-800 text-zinc-400">
            <RefreshCw className="w-4 h-4" />
          </button>
        </div>
      </div>

      {/* Pipeline Visualization */}
      <div className="grid grid-cols-3 gap-4">
        <PipelineStage icon={Shield} label="ZeroClaw Sanitizer" port={10932} active={health?.services?.zeroclaw === "healthy"} />
        <PipelineStage icon={Gavel} label="DeepSeek Adjudicator" port={10933} active={health?.services?.deepseek === "healthy"} />
        <PipelineStage icon={Wrench} label="Moltbot Worker" port={10934} active={health?.services?.moltbot === "healthy"} />
      </div>

      {/* Service Status Row */}
      <div className="flex gap-3 flex-wrap">
        {health?.services &&
          Object.entries(health.services).map(([name, status]) => (
            <ServiceStatus key={name} name={name} status={String(status)} />
          ))}
      </div>

      {/* Pipeline Input */}
      <div className="bg-zinc-900 border border-zinc-800 rounded-lg p-4 space-y-3">
        <h2 className="text-sm font-semibold text-zinc-400 flex items-center gap-2">
          <Play className="w-4 h-4" /> Pipeline Input
        </h2>
        <textarea
          value={input}
          onChange={(e) => setInput(e.target.value)}
          placeholder="Enter task or code to run through the pipeline..."
          className="w-full h-24 bg-zinc-950 border border-zinc-800 rounded p-3 text-sm text-zinc-200 placeholder-zinc-600 resize-none focus:outline-none focus:border-blue-500/50"
        />
        <button
          onClick={runPipeline}
          disabled={loading || !input.trim()}
          className="px-4 py-2 bg-blue-600 hover:bg-blue-500 disabled:bg-zinc-800 disabled:text-zinc-600 text-white rounded text-sm font-medium transition-colors"
        >
          {loading ? "Running..." : "Run Pipeline"}
        </button>
      </div>

      {/* Result */}
      {result && (
        <div className="bg-zinc-900 border border-zinc-800 rounded-lg p-4">
          <h2 className="text-sm font-semibold text-zinc-400 mb-2">Result</h2>
          <pre className="text-xs text-zinc-300 overflow-x-auto whitespace-pre-wrap">{result}</pre>
        </div>
      )}

      {/* Audit Log */}
      <div className="bg-zinc-900 border border-zinc-800 rounded-lg p-4 space-y-3">
        <div className="flex items-center justify-between">
          <h2 className="text-sm font-semibold text-zinc-400 flex items-center gap-2">
            <Clock className="w-4 h-4" /> Adjudication Log
          </h2>
          <button onClick={fetchAudit} className="text-xs text-zinc-500 hover:text-zinc-300">
            Refresh
          </button>
        </div>
        {auditLog.length === 0 ? (
          <p className="text-xs text-zinc-600">No adjudications yet.</p>
        ) : (
          <div className="space-y-2 max-h-64 overflow-y-auto">
            {auditLog.map((entry, i) => (
              <div key={i} className="flex items-start gap-3 p-2 rounded bg-zinc-950 border border-zinc-800 text-xs">
                <span className={`mt-0.5 ${entry.verdict === "approve" ? "text-green-400" : "text-red-400"}`}>
                  {entry.verdict === "approve" ? <CheckCircle className="w-3.5 h-3.5" /> : <AlertTriangle className="w-3.5 h-3.5" />}
                </span>
                <div className="flex-1 min-w-0">
                  <p className="text-zinc-300 truncate">{entry.content}</p>
                  <p className="text-zinc-600 mt-0.5">
                    {entry.verdict} — {entry.rationale?.slice(0, 80)}
                  </p>
                </div>
                <span className="text-zinc-600 shrink-0">{entry.timestamp?.slice(11, 19)}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
}
