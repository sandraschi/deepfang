# DeepFang — Goliath Docker-Compose Stack
# Copy to .env and fill in your values.

# ── DeepSeek-V4-Pro Adjudicator ────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Supervisor ─────────────────────────────────────────────────────────────
DEEPFANG_PORT=10930
DEEPFANG_DASHBOARD_PORT=10931

# ── Git Mirrors (worker writes here) ───────────────────────────────────────
GIT_ROOT=d:/dev/repos
